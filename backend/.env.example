# ============================================================
# AI Panel Studio — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# DeepSeek API 配置（必填）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 数据库路径（相对于 backend 目录）
DATABASE_PATH=./data/ai_panel_studio.db

# 服务端口
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# 日志级别: debug / info / warning / error
LOG_LEVEL=info

# SSE 心跳间隔（秒）
SSE_HEARTBEAT_INTERVAL=15

# DeepSeek 请求超时（秒）
DEEPSEEK_TIMEOUT=60
DEEPSEEK_STREAM_TIMEOUT=120

# 发言长度限制（中文字符数）
SPEECH_MIN_CHARS=20
SPEECH_MAX_CHARS=200

# 嘉宾生成人数限制
PANELIST_MIN_COUNT=1
PANELIST_MAX_COUNT=10
